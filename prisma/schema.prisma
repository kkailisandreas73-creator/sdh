generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum values stored as strings (BUYER, ADMIN, PENDING, etc.)

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         String   @default("BUYER")
  accountId    String?  @map("account_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account Account? @relation(fields: [accountId], references: [id])
  cart    Cart?
  quotes  Quote[]
  orders  Order[]
  audits  AuditLog[]

  @@map("users")
}

model Account {
  id            String        @id @default(cuid())
  companyName   String        @map("company_name")
  taxId         String?       @map("tax_id")
  status        String   @default("PENDING")
  tierId        String?  @map("tier_id")
  paymentTerms  String   @default("CARD_ONLY") @map("payment_terms")
  approvedAt    DateTime?     @map("approved_at")
  approvedById  String?       @map("approved_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  users              User[]
  addresses          Address[]
  priceOverrides     AccountPriceOverride[]
  quotes             Quote[]
  orders             Order[]

  @@map("accounts")
}

model Address {
  id        String      @id @default(cuid())
  accountId String      @map("account_id")
  type      String
  line1     String
  line2     String?
  city      String
  state     String
  zip       String
  country   String      @default("US")
  isDefault Boolean     @default(false) @map("is_default")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  parentId  String?   @map("parent_id")
  vertical  String
  sortOrder Int       @default(0) @map("sort_order")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id                   String   @id @default(cuid())
  sku                  String   @unique
  name                 String
  slug                 String   @unique
  description          String
  categoryId           String   @map("category_id")
  brand                String?
  moq                  Int      @default(1)
  allowInstantCheckout Boolean  @default(true) @map("allow_instant_checkout")
  quoteOnly            Boolean  @default(false) @map("quote_only")
  isActive             Boolean  @default(true) @map("is_active")
  metadata             String?  // JSON string
  tags                 String?  // comma-separated for search
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  category       Category               @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  inventory      Inventory?
  priceTiers     PriceTier[]
  priceOverrides AccountPriceOverride[]
  cartItems      CartItem[]
  quoteLines     QuoteLine[]
  orderLines     OrderLine[]

  @@index([categoryId, isActive])
  @@map("products")
}

model ProductImage {
  id        String @id @default(cuid())
  productId String @map("product_id")
  url       String
  alt       String?
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Inventory {
  productId       String @id @map("product_id")
  quantityOnHand  Int    @default(0) @map("quantity_on_hand")
  reserved        Int    @default(0)
  reorderPoint    Int?   @map("reorder_point")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model PriceList {
  id        String   @id @default(cuid())
  name      String
  currency  String   @default("USD")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  tiers PriceTier[]

  @@map("price_lists")
}

model PriceTier {
  id          String  @id @default(cuid())
  priceListId String  @map("price_list_id")
  productId   String  @map("product_id")
  minQty      Int     @map("min_qty")
  unitPrice   Float   @map("unit_price")

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId, minQty])
  @@map("price_tiers")
}

model AccountPriceOverride {
  id         String    @id @default(cuid())
  accountId  String    @map("account_id")
  productId  String    @map("product_id")
  unitPrice  Float     @map("unit_price")
  validFrom  DateTime  @default(now()) @map("valid_from")
  validTo    DateTime? @map("valid_to")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("account_price_overrides")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String @map("cart_id")
  productId String @map("product_id")
  quantity  Int

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Quote {
  id          String      @id @default(cuid())
  accountId   String      @map("account_id")
  userId      String      @map("user_id")
  status      String @default("DRAFT")
  buyerNotes  String?     @map("buyer_notes")
  adminNotes  String?     @map("admin_notes")
  validUntil  DateTime?   @map("valid_until")
  submittedAt DateTime?   @map("submitted_at")
  quotedAt    DateTime?   @map("quoted_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  account Account     @relation(fields: [accountId], references: [id])
  user    User        @relation(fields: [userId], references: [id])
  lines   QuoteLine[]
  orders  Order[]

  @@index([accountId, status])
  @@map("quotes")
}

model QuoteLine {
  id               String  @id @default(cuid())
  quoteId          String  @map("quote_id")
  productId        String  @map("product_id")
  quantity         Int
  requestedPrice   Float?  @map("requested_price")
  quotedUnitPrice  Float?  @map("quoted_unit_price")
  lineNotes        String? @map("line_notes")

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("quote_lines")
}

model Order {
  id                    String        @id @default(cuid())
  accountId             String        @map("account_id")
  userId                String        @map("user_id")
  quoteId               String?       @map("quote_id")
  status                String @default("DRAFT")
  paymentMethod         String @map("payment_method")
  subtotal              Float
  tax                   Float           @default(0)
  shipping              Float           @default(0)
  total                 Float
  poNumber              String?         @map("po_number")
  stripePaymentIntentId String?         @map("stripe_payment_intent_id")
  internalNotes         String?         @map("internal_notes")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  account   Account     @relation(fields: [accountId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
  quote     Quote?      @relation(fields: [quoteId], references: [id])
  lines     OrderLine[]
  shipments Shipment[]

  @@index([accountId, createdAt])
  @@map("orders")
}

model OrderLine {
  id           String @id @default(cuid())
  orderId      String @map("order_id")
  productId    String @map("product_id")
  skuSnapshot  String @map("sku_snapshot")
  nameSnapshot String @map("name_snapshot")
  quantity     Int
  unitPrice    Float  @map("unit_price")
  lineTotal    Float  @map("line_total")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_lines")
}

model Shipment {
  id             String    @id @default(cuid())
  orderId        String    @map("order_id")
  carrier        String?
  trackingNumber String?   @map("tracking_number")
  shippedAt      DateTime? @map("shipped_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

model StaticPage {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  content String

  @@map("static_pages")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  @map("actor_id")
  entity    String
  entityId  String   @map("entity_id")
  action    String
  payload   String?
  createdAt DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}
